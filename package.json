{
  "name": "bytebank-multizones-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:home\" \"npm run dev:app\"",
    "dev:home": "npm run dev --workspace=bytebank-home",
    "dev:app": "npm run dev --workspace=bytebank-app",
    "dev:backend": "cross-env port=3002 npm run dev --prefix backend/tech-challenge-2",
    "build:home": "npm run build --workspace=bytebank-home",
    "build:app": "npm run build --workspace=bytebank-app",
    "start": "concurrently \"npm run start:home\" \"npm run start:app\"",
    "start:home": "npm run start --workspace=bytebank-home",
    "start:app": "npm run start --workspace=bytebank-app",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint --workspaces --if-present -- --fix",
    "install-deps": "npm install --workspaces",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3"
  }
}
